# ============================================================================
# .env.example
#
# Copy this file to `.env` and fill in real values.
# DO NOT commit `.env` to git — only this example file.
# ============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ASK_ACME_ENV=development          # development | staging | production
ASK_ACME_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
ASK_ACME_DEBUG=false

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# Used by the postgres container on first boot AND by the app to connect.
POSTGRES_USER=acme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=acme
# localhost is correct when you run the app/tests directly on your machine
# against `docker compose up` (ports are published to the host). The compose
# app service hardcodes POSTGRES_HOST=postgres for in-network use, so you do
# NOT need to change this to run inside Docker.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
# localhost for host-machine runs (see POSTGRES_HOST note above); the compose
# app service hardcodes QDRANT_HOST=qdrant for in-network use.
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                   # leave blank for local dev; set in prod
QDRANT_COLLECTION=ask_acme_docs

# ---------------------------------------------------------------------------
# External APIs
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx        

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
ASK_ACME_HOST=0.0.0.0
ASK_ACME_PORT=8000